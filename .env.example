# === Plantilla de configuración ===
# Copia este archivo como .env y rellena los valores reales.

PORT=3000
NODE_ENV=development

# Motor: 'mysql' o 'postgres'
DB_CLIENT=mysql
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=servicio_comunitario
DB_PORT=3306

CORS_ORIGIN=http://localhost:3000

# Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=cambia-esto-por-un-valor-aleatorio-largo

# === Producción (Vercel + Supabase) ===
# DB_CLIENT=postgres
# DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-xxx.pooler.supabase.com:6543/postgres
#
# Supabase Storage para las fotos de referencia (bucket privado):
# SUPABASE_URL=https://[REF].supabase.co
# SUPABASE_SERVICE_KEY=  (Settings -> API -> service_role key; NO la anon)
# SUPABASE_BUCKET=referencias
